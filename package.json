{
  "name": "@lamartinecabral/extract-content",
  "version": "0.0.3",
  "description": "A utility library to extract web page content optimized for RAG workflows",
  "author": "lamartinecabral",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "content-extraction",
    "rag",
    "web-scraping",
    "dom",
    "text-extraction",
    "markdown",
    "browser"
  ],
  "files": [
    "./dist/index.js",
    "./dist/index.d.ts"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "tsc",
    "tag": "v=$(node -p \"'v'+require('./package.json').version\") && git tag $v && git push origin $v",
    "version:patch": "npm --no-git-tag-version version patch"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3"
  }
}
